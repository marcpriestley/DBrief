+    // Returns true for types that accumulate (sum), false for types that are averaged (discrete)
+    func isCumulativeType(_ dataType: String) -> Bool {
+        let cumulativeTypes: Set<String> = ["steps", "active-calories", "flights-climbed", "walking-distance", "exercise-minutes"]
+        return cumulativeTypes.contains(dataType)
+    }
+    
+    // Extracts the correct double value from an HKQuantity for a given data type
+    func extractValue(from quantity: HKQuantity, dataType: String) -> Double {
+        switch dataType {
+        case "steps", "flights-climbed":
+            return quantity.doubleValue(for: HKUnit.count())
+        case "active-calories":
+            return quantity.doubleValue(for: HKUnit.kilocalorie())
+        case "walking-distance":
+            return quantity.doubleValue(for: HKUnit.meter()) / 1000.0 // convert to km
+        case "exercise-minutes":
+            return quantity.doubleValue(for: HKUnit.minute())
+        case "heart-rate", "resting-heart-rate":
+            return quantity.doubleValue(for: HKUnit.count().unitDivided(by: HKUnit.minute()))
+        case "hrv":
+            return quantity.doubleValue(for: HKUnit(from: "ms"))
+        case "oxygen-saturation", "body-fat":
+            return quantity.doubleValue(for: HKUnit.percent()) * 100.0
+        case "body-mass":
+            return quantity.doubleValue(for: HKUnit.gramUnit(with: .kilo))
+        case "respiratory-rate":
+            return quantity.doubleValue(for: HKUnit.count().unitDivided(by: HKUnit.minute()))
+        default:
+            return -1.0
+        }
+    }
